+def classify_source_family(source, observation_type=None):
+    """Classify source_family.
+
+    Prefer the explicit observation_type propagated from s3/s5. Fall back to
+    source-name heuristics so older s5 CSVs without observation_type continue
+    to run.
+    """
+    obs_text = "" if observation_type is None else str(observation_type).strip()
+    obs_low = obs_text.lower().replace("-", "_").replace(" ", "_")
+    if obs_low:
+        if obs_low in {"usgs", "hydat", "satellite", "in_situ", "secondary_compilation"}:
+            return obs_low if obs_low not in {"usgs", "hydat"} else obs_low.upper()
+        if obs_low in {"insitu", "in_situ_observation", "station", "station_observation", "gauge", "gauge_observation"}:
+            return "in_situ"
+        if obs_low in {"remote_sensing", "remote_sensing_observation", "satellite_observation"}:
+            return "satellite"
+        if obs_low in {"compiled", "compilation", "secondary", "secondary_dataset"}:
+            return "secondary_compilation"
+
